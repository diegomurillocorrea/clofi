# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# UUID de la organización (public.organizations)
CLOFI_ORGANIZATION_ID=

# Server-only — required for Clofi writes while RLS is enabled (never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=
